# py-lazer-server configuration

# Server settings
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
SERVER_MODE=development

# Database
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./osu.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/osu

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE IN PRODUCTION
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth2 Client settings
OAUTH_CLIENT_ID=5
OAUTH_CLIENT_SECRET=change-me

# External URLs
API_BASE_URL=http://localhost:8000
WEBSITE_URL=http://localhost:8000

# File storage paths
BEATMAPS_PATH=./data/beatmaps
REPLAYS_PATH=./data/replays
AVATARS_PATH=./data/avatars

# Rate limiting
RATE_LIMIT_REQUESTS=1200
RATE_LIMIT_WINDOW_SECONDS=600

# Beatmap mirror settings
# When true, uses internal mirror (requires IP whitelist for some endpoints)
# When false, uses official osu! API directly (requires osu_api credentials)
USE_BEATMAP_MIRROR=true
BEATMAP_MIRROR_URL=https://beatmaps.akatsuki.gg

# Official osu! API v2 credentials (required when USE_BEATMAP_MIRROR=false)
# Create an OAuth application at: https://osu.ppy.sh/home/account/edit#oauth
OSU_API_CLIENT_ID=
OSU_API_CLIENT_SECRET=
